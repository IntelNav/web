# Next.js build output (static export). Keep source under src/ in git
# and build fresh on every deploy.
.next/
out/

# Dependencies — npm install is fast enough that we don't commit them.
node_modules/

# Editor / OS junk.
.DS_Store
*.swp
.idea/
.vscode/

# Env files — never commit secrets.
.env
.env.local
.env.*.local

# Build cache / logs.
*.log
.eslintcache

# Generated by Next.js
next-env.d.ts

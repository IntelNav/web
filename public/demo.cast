[25.070934, "o", "\u001b[3;1H      \u001b[3m\u001b[38;2;136;136;136;49m/model    <name>                switch active model\u001b[23m\u001b[39;49m                                                                         \u001b[4;1H      \u001b[3m\u001b[38;2;136;136;136;49m/models\u001b[4;15H \u001b[4;17H open\u001b[4;23Hthe model picker\u001b[23m\u001b[39;49m       \u001b[4;130H \u001b[5;1H \u001b[5;7H\u001b[3m\u001b[38;2;136;136;136;49m/hosting   view + manage slices you host\u001b[5;130H\u001b[23m\u001b[39;49m \u001b[6;1H      \u001b[3m\u001b[38;2;136;136;136;49m/leave    [<n> | <cid> <start> <end>]  drain a hosted slice (no args to pick from a list)\u001b[6;130H\u001b[23m\u001b[39;49m \u001b[7;1H      \u001b[3m\u001b[38;2;136;136;136;49m/service  <install|status|uninstall>  manage the intelnav-node systemd unit\u001b[23m\u001b[39;49m        \u001b[7;130H \u001b[8;1H      \u001b[3m\u001b[38;2;136;136;136;49m/keybindings  list every keyboard shortcut\u001b[8;51H\u001b[23m\u001b[39;49m                       \u001b[8;130H \u001b[9;1H      \u001b[3m\u001b[38;2;136;136;136;49m/doctor    runtime snapshot\u001b[23m\u001b[39;49m               \u001b[9;51H                                  \u001b[9;130H \u001b[10;1H      \u001b[3m\u001b[38;2;136;136;136;49m/quorum   <n>                   set replication quorum\u001b[23m\u001b[39;49m             \u001b[10;130H \u001b[11;1H      \u001b[3m\u001b[38;2;136;136;136;49m/tier     <lan|cont|wan>        set network tier\u001b[23m\u001b[39;49m                              \u001b[11;130H \u001b[12;1H \u001b[12;7H\u001b[3m\u001b[38;2;136;136;136;49m/peers    [host:port,... split,...]  configure pipeline peer chain\u001b[12;130H\u001b[23m\u001b[39;49m \u001b[13;1H \u001b[13;7H\u001b[3m\u001b[38;2;136;136;136;49m/draft    [path.gguf k]         enable speculative decoding\u001b[13;130H\u001b[23m\u001b[39;49m \u001b[14;1H \u001b[14;7H\u001b[3m\u001b[38;2;136;136;136;49m/wire     <fp16|int8>           activation dtype on the chain\u001b[14;130H\u001b[23m\u001b[39;49m \u001b[15;1H \u001b[15;7H\u001b[3m\u001b[38;2;136;136;136;49m/quit      exit the app\u001b[15;130H\u001b[23m\u001b[39;49m \u001b[16;1H \u001b[16;130H \u001b[17;1H\u001b[3m\u001b[38;2;128;128;128;49msys  \u001b[17;7H\u001b[38;2;136;136;136;49mkeybindings:\u001b[17;130H\u001b[23m\u001b[39;49m \u001b[18;1H \u001b[18;7H\u001b[3m\u001b[38;2;136;136;136;49m\u21b5                  send the prompt\u001b[18;130H\u001b[23m\u001b[39;49m \u001b[19;1H \u001b[19;7H\u001b[3m\u001b[38;2;136;136;136;49mshift + \u21b5          newline (also: \\ + \u21b5)\u001b[19;130H\u001b[23m\u001b[39;49m \u001b[20;1H \u001b[20;7H\u001b[3m\u001b[38;2;"]
[25.071003, "o", "136;136;136;49mesc esc            clear input (double-tap within 600 ms)\u001b[20;130H\u001b[23m\u001b[39;49m \u001b[21;1H \u001b[21;7H\u001b[3m\u001b[38;2;136;136;136;49mctrl + c           cancel stream / clear input. twice within 1.5s = quit\u001b[21;130H\u001b[23m\u001b[39;49m \u001b[22;1H \u001b[22;7H\u001b[3m\u001b[38;2;136;136;136;49mctrl + d           quit when input is empty\u001b[22;130H\u001b[23m\u001b[39;49m \u001b[23;1H \u001b[23;7H\u001b[3m\u001b[38;2;136;136;136;49mctrl + l           clear transcript\u001b[23;130H\u001b[23m\u001b[39;49m \u001b[24;1H \u001b[24;7H\u001b[3m\u001b[38;2;136;136;136;49mctrl + g           edit current input in $EDITOR\u001b[24;130H\u001b[23m\u001b[39;49m \u001b[25;1H \u001b[25;7H\u001b[3m\u001b[38;2;136;136;136;49mctrl + shift + _   undo last input edit\u001b[25;130H\u001b[23m\u001b[39;49m \u001b[26;1H \u001b[26;7H\u001b[3m\u001b[38;2;136;136;136;49malt + p            cycle to next cached model\u001b[26;130H\u001b[23m\u001b[39;49m \u001b[27;1H \u001b[27;7H\u001b[3m\u001b[38;2;136;136;136;49m\u2191 / \u2193              prompt history (when cursor is on first/last input row)\u001b[27;130H\u001b[23m\u001b[39;49m \u001b[28;1H \u001b[28;7H\u001b[3m\u001b[38;2;136;136;136;49mtab                accept slash-completion\u001b[28;130H\u001b[23m\u001b[39;49m \u001b[29;1H \u001b[29;7H\u001b[3m\u001b[38;2;136;136;136;49mpage up / down     scroll transcript\u001b[29;130H\u001b[23m\u001b[39;49m \u001b[30;1H \u001b[30;7H\u001b[3m\u001b[38;2;136;136;136;49mshift + home/end   jump to start/end of transcript\u001b[30;130H\u001b[23m\u001b[39;49m \u001b[31;1H \u001b[31;7H\u001b[3m\u001b[38;2;136;136;136;49mctrl + z           suspend (terminal default; resume with `fg`)\u001b[31;130H\u001b[23m\u001b[39;49m \u001b[32;1H \u001b[32;130H \u001b[33;1H\u001b[3m\u001b[38;2;128;128;128;49msys  \u001b[33;7H\u001b[38;2;136;136;136;49minstalling Qwen 2.5 \u00b7 0.5B \u00b7 Instruct \u2192 /home/islam/.local/share/intelnav/models\u001b[33;1
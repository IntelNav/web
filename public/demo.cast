[140.371658, "o", "\u001b[3;1H     \u001b[3;7H\u001b[3m\u001b[38;2;136;136;136;49mctrl + c   \u001b[3;19H    \u001b[3;24H  cancel stream / clear\u001b[3;48Hinput. twic\u001b[3;61Hwithin 1.5s = quit\u001b[23m\u001b[39;49m               \u001b[4;7H\u001b[3m\u001b[38;2;136;136;136;49mctrl + d           quit when input is empty\u001b[5;1H\u001b[23m\u001b[39;49m     \u001b[5;7H\u001b[3m\u001b[38;2;136;136;136;49mctrl + l           clear transcript\u001b[6;7Hctrl + g           edit current input in $EDITOR\u001b[7;1H\u001b[23m\u001b[39;49m     \u001b[7;7H\u001b[3m\u001b[38;2;136;136;136;49mctrl + shift + _   undo last input edit\u001b[23m\u001b[39;49m                       \u001b[8;7H\u001b[3m\u001b[38;2;136;136;136;49malt + p            cycle to next cached model\u001b[9;7H\u2191 / \u2193              prompt history (when cursor is on first/last input row)\u001b[23m\u001b[39;49m    \u001b[10;7H\u001b[3m\u001b[38;2;136;136;136;49mtab                accept slash-completion\u001b[11;7Hpage up / down     scroll transcript\u001b[12;7Hshift + home/end   jump to start/end of transcript\u001b[13;7Hctrl + z           suspend (terminal default; resume with `fg`)\u001b[14;7H\u001b[23m\u001b[39;49m                                                                "]
[140.37168, "o", "                                                       \u001b[15;1H\u001b[3m\u001b[38;2;128;128;128;49msys  \u001b[15;7H\u001b[38;2;136;136;136;49minstalling Qwen 2.5 \u00b7 0.5B \u00b7 Instruct \u2192 /home/islam/.local/share/intelnav/models\u001b[17;1H\u001b[38;2;128;128;128;49msys  \u001b[23m\u001b[39;49m \u001b[3m\u001b[38;2;136;136;136;49m\u2713 installed Qwen 2.5 \u00b7 0.5B \u00b7 Instruct \u2014 ready to use as `qwen2.5-0.5b-instruct-q4_k_m`\u001b[23m\u001b[39;49m                                     \u001b[18;1H             \u001b[18;16H             \u001b[18;130H \u001b[19;1H\u001b[1m\u001b[38;2;122;180;232;49myou  \u001b[22m\u001b[39;49m \u001b[38;2;230;230;230;49mwh\u001b[19;10Ht\u001b[19;12His 17 squared?\u001b[39;49m          \u001b[19;130H \u001b[20;1H             \u001b[20;15H               \u001b[20;32H                 \u001b[20;130H \u001b[21;1H\u001b[1m\u001b[38;2;217;119;87;49mintel\u001b[22m\u001b[39;49m \u001b[38;2;230;230;230;49mTh\u001b[21;10H answer to \"17 squared\" (written as \\( 17^2 \\)) is **289**.\u001b[21;130H\u001b[39;49m \u001b[22;1H             \u001b[22;16H                     \u001b[22;130H \u001b[23;1H      \u001b[38;2;230;230;230;49mIn mathematics, squaring a number means multiplying it by itself. For example:\u001b[23;"]
[140.371698, "o", "130H\u001b[39;49m \u001b[24;1H             \u001b[24;15H                           \u001b[24;44H                                                  \u001b[24;130H \u001b[25;1H      \u001b[38;2;230;230;230;49m- \\( 5^2 = 5 \\times 5 = 25 \\)\u001b[39;49m     \u001b[25;43H                                     \u001b[25;130H \u001b[26;1H      \u001b[38;2;230;230;230;49m- \\( -3^2 = (-3) \\times (-3) = 9 \\)\u001b[39;49m     \u001b[26;130H \u001b[27;1H             \u001b[27;16H                \u001b[27;130H \u001b[28;1H      \u001b[38;2;230;230;230;49mS\u001b[28;9H for\u001b[28;14Hany number, whether positive or negative, the square of that number is simply its numerical value multiplied by \u001b[28;130H\u001b[39;49m \u001b[29;1H      \u001b[29;8H\u001b[38;2;230;230;230;49mtself.\u001b[29;15H\u001b[39;49m              \u001b[29;31H                \u001b[29;130H \u001b[30;1H             \u001b[30;15H                         \u001b[30;42H                             \u001b[30;130H \u001b[31;1H\u001b[38;2;136;136;136;49m\u250c commands \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[32;2H\u001b[38;2;217;119;87;49m \u203a \u001b[1m/quorum  \u001b[32;16H\u001b[22m\u001b[38;2;85;85;85;49mn>\u001b[39;49m  \u001b[38;2;136;136;136;49mset repli\u001b[32;30Hation quorum\u001b[39;49m               \u001b[
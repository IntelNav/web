{"version": 2, "width": 130, "height": 38, "timestamp": 1777423119, "idle_time_limit": 1.5, "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}, "title": "intelnav — multi-peer chain, real prompt"}
[0.004315, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.00507, "o", "\r\n  intelnav — three peer daemons, one chat client, one chain.\r\n  every wire is the real protocol; this is just sandboxed onto one box.\r\n\r\n"]
[2.006159, "o", "\u001b[2;36m# 1. setup the sandbox (4-way layer split of Qwen 2.5 · 0.5B)\u001b[0m\r\n"]
[2.70732, "o", "\u001b[1;38;5;243m$ \u001b[0mbash scripts/local-swarm.sh setup\r\n"]
[3.210541, "o", "\u001b[36m→ wiping any prior swarm state at /tmp/intelnav-swarm\u001b[0m\r\n"]
[3.218792, "o", "\u001b[32m✓ swarm prepared at /tmp/intelnav-swarm\u001b[0m\r\n"]
[4.722308, "o", "\r\n\u001b[2;36m# 2. spawn three intelnav-node daemons (ports 17717/17718/17719)\u001b[0m\r\n"]
[5.323448, "o", "\u001b[1;38;5;243m$ \u001b[0mbash scripts/local-swarm.sh start\r\n"]
[5.827299, "o", "\u001b[32m✓ started peer-a pid=256872 port=17717 layers=6 12\u001b[0m\r\n"]
[5.828269, "o", "\u001b[32m✓ started peer-b pid=256875 port=17718 layers=12 18\u001b[0m\r\n"]
[5.829298, "o", "\u001b[32m✓ started peer-c pid=256890 port=17719 layers=18 24\u001b[0m\r\n"]
[5.829343, "o", "\u001b[36m→ waiting 2 s for daemons to bind...\u001b[0m\r\n"]
[7.831338, "o", "\u001b[32m  ✓ peer-a: TCP 17717 reachable\u001b[0m\r\n"]
[7.831884, "o", "\u001b[32m  ✓ peer-b: TCP 17718 reachable\u001b[0m\r\n"]
[7.83241, "o", "\u001b[32m  ✓ peer-c: TCP 17719 reachable\u001b[0m\r\n"]
[10.333911, "o", "\r\n\u001b[2;36m# 3. status: who is up, what they own\u001b[0m\r\n"]
[10.835029, "o", "\u001b[1;38;5;243m$ \u001b[0mbash scripts/local-swarm.sh status\r\n"]
[11.339894, "o", "  peer-a  running    pid=256872  forward=127.0.0.1:17717  layers=6 12\r\n"]
[11.341685, "o", "  peer-b  running    pid=256875  forward=127.0.0.1:17718  layers=12 18\r\n"]
[11.343744, "o", "  peer-c  running    pid=256890  forward=127.0.0.1:17719  layers=18 24\r\n"]
[13.34485, "o", "\r\n\u001b[2;36m# 4. drive a real prompt through the chain — driver runs 0..6 locally,\u001b[0m\r\n"]
[13.344953, "o", "\u001b[2;36m#    forwards hidden states through 6..12 → 12..18 → 18..24 → tokens come back.\u001b[0m\r\n"]
[14.346024, "o", "\u001b[1;38;5;243m$ \u001b[0mbash scripts/local-swarm.sh ask \"what is 17 squared?\"\r\n"]
[14.851826, "o", "\u001b[36m→ asking the swarm: what is 17 squared?\u001b[0m\r\n"]
